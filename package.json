{
  "name": "raar-admin-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production && npm run package",
    "package": "cd dist/raar-admin-ui/browser && gzip -kf *.js *.css && tar czf ../../raar-admin-ui.tar.gz .",
    "lint": "ng lint",
    "format": "prettier --write \"./**/*.{js,ts,json,css,scss,html,md,yaml}\"",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:once": "npm run cy:once:prepare && npm run cy:once:serve_and_run",
    "cy:once:serve_and_run": "run-p --race cy:once:serve cy:run",
    "cy:once:prepare": "npm run build && ln -sf index.html dist/raar-admin-ui/404.html",
    "cy:once:serve": "http-server ./dist/raar-admin-ui -a localhost -p 4200 -c-1"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "bootstrap-sass": "^3.4.1",
    "core-js": "^3.6.4",
    "rxjs": "^7.8.2",
    "tslib": "^2.0.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.17",
    "@angular/language-service": "^21.2.17",
    "@types/node": "^22.18.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.60.0",
    "cypress": "^15.16.0",
    "eslint": "^9.38.0",
    "http-server": "^14.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.0",
    "ts-node": "^8.8.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "sass": "1.77.6"
  }
}
